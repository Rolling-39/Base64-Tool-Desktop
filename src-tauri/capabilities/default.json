{
  "identifier": "default",
  "description": "Default capability for Base64 Tool",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "clipboard-manager:allow-write-text"
  ]
}
