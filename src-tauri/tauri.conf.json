{
  "productName": "Base64 Tool",
  "version": "1.0.0",
  "identifier": "com.rolling.base64-tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Base64 Tool",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 540,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
